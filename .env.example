# Stellar Wallet Configuration
# Copy this file to .env and fill in your real values
# NEVER commit your .env file to GitHub

# Your Stellar wallet secret key (starts with S)
SENDER_SECRET=your_stellar_secret_key_here

# Contributor Stellar wallet public key (starts with G)
RECIPIENT_PUBLIC=recipient_stellar_public_key_here

# Stellar Network — use testnet for development, mainnet for production
# Options: testnet | mainnet
STELLAR_NETWORK=testnet